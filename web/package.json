{
  "name": "minilogue-xd-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "biome check --write",
    "lint": "biome lint",
    "format": "biome format --write",
    "build:schema": "tsx scripts/build-schema.ts",
    "copy:ort": "node scripts/copy-ort.mjs",
    "postinstall": "node scripts/copy-ort.mjs"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.9.0",
    "@google/genai": "^1.0.0",
    "@vercel/blob": "^0.27.0",
    "fflate": "^0.8.3",
    "onnxruntime-web": "^1.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
