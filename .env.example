# Copy to .env (gitignored) for local use, and set the same values in the Vercel project
# dashboard for production. None are required to run the app locally, but the public
# deployment needs the SERVER + CLIENT groups for rate-limiting and the captcha to work.

# ── Server: Vercel project env (set in the Vercel dashboard) ───────────────────────────
# Vercel Blob store token — auto-added when you create a Blob store. Stores contribution audio.
BLOB_READ_WRITE_TOKEN=

# Admin token gating GET /api/contributions. Generate a random secret (e.g. `openssl rand -hex 32`).
# The Python puller + daemon send this as `Authorization: Bearer <token>`.
CONTRIB_ADMIN_TOKEN=

# Vercel KV (Upstash) — auto-added when you link a KV store. Enables per-IP rate limiting on
# /api/contribute. If unset, rate limiting is skipped (fails open).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cloudflare Turnstile secret key. Enables server-side captcha verification on /api/contribute.
# If unset, the captcha check is skipped — set it for a public deployment.
TURNSTILE_SECRET_KEY=

# ── Client: Vite build-time (repo-root .env locally — Vite envDir; "Build" env in Vercel) — VITE_-prefixed ─
# Cloudflare Turnstile site key (public). Renders the captcha widget in the re-synth feedback flow.
VITE_TURNSTILE_SITE_KEY=

# Optional: shared token the localhost app sends to the local daemon as X-Daemon-Token.
# Must match DAEMON_TOKEN below. Leave unset to rely on the daemon's origin allowlist alone.
VITE_DAEMON_TOKEN=

# Deployed web app URL the Ableton embed links to ("Web version", opened in the system
# browser). Baked into the embed build; defaults to https://minilogue-xd-viewer.vercel.app/.
VITE_WEB_URL=https://minilogue-xd-viewer.vercel.app/

# Feature flag for the audio→patch Resynthesis button. Falsy/unset disables the button and the
# resynth JS is never loaded; truthy lazy-loads it on first click. Set per environment
# (web/.env locally, Vercel "Build" env for production).
VITE_RESYNTH_ENABLED=true

# ── Python training / daemon: shell env when running the puller or daemon locally ──────────
# Deployed app base URL — enables the daemon's remote pull and training/data/pull_contributions.py.
CONTRIB_API_URL=https://your-app.vercel.app

# CONTRIB_ADMIN_TOKEN — same value as the server one above (the puller/daemon authenticate with it).

# Optional: require X-Daemon-Token on the local daemon's /verify (pair with VITE_DAEMON_TOKEN).
DAEMON_TOKEN=

# Optional: override the allowed Blob host for the SSRF guard if you use a custom blob domain.
# CONTRIB_BLOB_HOST_SUFFIX=.public.blob.vercel-storage.com
